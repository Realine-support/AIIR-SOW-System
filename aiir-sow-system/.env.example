# ============================================
# AIIR SOW Automation System - Environment Variables
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it contains secrets)

# === OpenAI Configuration ===
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# === Google Cloud Configuration ===
# Path to your Google service account JSON file
GOOGLE_CREDENTIALS_PATH=/path/to/service-account.json
# Service account email
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# === Google Drive/Sheets IDs ===
# Main tracker sheet ID (from Google Sheets URL)
TRACKER_SHEET_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TRACKER_TAB_NAME=Tracker

# Calculator template sheet ID
CALCULATOR_SHEET_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CALCULATOR_TAB_NAME=Calculator

# === Shared Drive Configuration ===
# Your Google Shared Drive ID
SHARED_DRIVE_ID=0XXXXXXXXXXXXXXXXXXXXXXXXXX

# === Template IDs ===
# Google Sheets template for pricing calculator
CALCULATOR_TEMPLATE_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Google Docs template for SOW document
SOW_TEMPLATE_DOC_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# === Folder IDs (All in Shared Drive) ===
# Folder where transcripts are uploaded
TRANSCRIPTS_FOLDER_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Folder where pricing rationales are stored
RATIONALES_FOLDER_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Folder where SOW templates are stored
SOW_TEMPLATES_FOLDER_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Folder for client-specific documents
CLIENT_DOCUMENTS_FOLDER_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Master folder for all clients
CLIENT_MASTER_FOLDER_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Archive folder for completed projects
ARCHIVE_FOLDER_ID=1XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# === Email Configuration ===
# Gmail address to send from (must be authorized in service account)
GMAIL_SEND_AS=your-email@company.com
# Email to receive review notifications
REVIEW_EMAIL_TO=reviewer@company.com
# Email address clients will see as sender
CLIENT_EMAIL_FROM=your-email@company.com

# === Gmail OAuth2 Configuration (Optional - for sending emails) ===
GMAIL_USE_OAUTH2=false
GMAIL_REFRESH_TOKEN=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# === Upstash Redis Configuration ===
# NOT USED - Redis is optional, system works without it
# Get these from https://console.upstash.com/ (if you decide to use Redis)
# UPSTASH_REDIS_REST_URL=https://xxxxxxxxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=AXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXx

# === Application Configuration ===
# Base URL for your deployment
BASE_URL=https://your-railway-app.railway.app
# Environment: development, staging, or production
ENVIRONMENT=production
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Debug mode: true for development, false for production
DEBUG=false
