{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "crons": [
    {
      "path": "/cron/watch-transcripts",
      "schedule": "*/5 * * * *"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  }
}
