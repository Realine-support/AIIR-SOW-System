    {
      "id": "w3_n4b_create_subfolders",
      "name": "Build Archive Folder Paths",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1350,
        300
      ],
      "parameters": {
        "jsCode": "const clientFolderResult = $input.first().json;\nconst prevData = $('Parse Full Data').first().json;\n// The created folder ID is the client's main folder\nconst clientFolderId = clientFolderResult.id;\nreturn [{ json: { ...prevData, clientFolderId } }];"
      }
    },
