      "typeVersion": 1,
      "position": [
        470,
        480
      ],
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html><html><body style='font-family:Arial;text-align:center;padding:60px;'><h1 style='color:#0f9d58;'>✅ SOW Approved & Sent</h1><p>The SOW has been approved and is being sent to the client.</p><p>Files are being archived. The tracker has been updated.</p></body></html>",
        "options": {
          "responseCode": 200,
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "text/html"
              }
            ]
          }
        }
      }
    },
    {
      "id": "w3_n2_read_tracker",
      "name": "Read Tracker Row",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        470,
        300
      ],
      "parameters": {
        "operation": "read",
        "documentId": {
          "__rl": true,
          "value": "={{$vars.AIIR_PRICING_SHEET_ID}}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Tracker",
          "mode": "name"
        },
        "filtersUI": {
          "values": [
            {
              "lookupColumn": "engagement_id",
              "lookupValue": "={{ $json.query.id }}"
            }
          ]
        },
        "options": {
          "returnFirstMatch": true
        }
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "id": "w3_n2b_parse",
      "name": "Parse Full Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        690,
        300
      ],
      "parameters": {
        "jsCode": "const row = $input.first().json;\nlet fullVars = {};\ntry { fullVars = JSON.parse(row.full_variables_json || '{}'); } catch(e) {}\n\nconst engagementId = row.engagement_id;\nconst clientCompany = row.client_company || fullVars.client_company || 'Unknown_Client';\nconst coacheeName = row.coachee_name || fullVars.coachee_name || 'Unknown';\nconst clientEmail = row.client_email || fullVars.client_email || null;\nconst hubspotDealId = row.hubspot_deal_id || fullVars.hubspot_deal_id || null;\nconst totalPrice = parseFloat((row.total_engagement_price || '0').toString().replace(/[,$]/g, '')) || 0;\nconst paymentStructure = row.payment_structure || fullVars.paymentStructure || '100% invoiced upon program kickoff';\nconst netDays = parseInt(row.net_days) || 30;\n\n// Extract doc IDs from URLs\nconst sowDocUrl = row.sow_doc_url || '';\nconst sowDocIdMatch = sowDocUrl.match(/\\/document\\/d\\/([^/]+)/);\nconst sowDocId = sowDocIdMatch ? sowDocIdMatch[1] : null;\n\nconst rationaleDocUrl = row.rationale_doc_url || '';\nconst rationaleDocIdMatch = rationaleDocUrl.match(/\\/document\\/d\\/([^/]+)/);\nconst rationaleDocId = rationaleDocIdMatch ? rationaleDocIdMatch[1] : null;\n\n// Transcript file ID from full vars\nconst transcriptFileId = fullVars.fileId || fullVars.id || null;\n\nconst today = new Date().toISOString().split('T')[0];\nconst clientFolderSafeName = clientCompany.replace(/[^a-zA-Z0-9 _-]/g, '').trim();\n\nreturn [{ json: {\n  ...fullVars,\n  ...row,\n  engagementId,\n  clientCompany,\n  coacheeName,\n  clientEmail,\n  hubspotDealId,\n  totalPrice,\n  totalPriceFormatted: '$' + Math.round(totalPrice).toLocaleString('en-US'),\n  paymentStructure,\n  netDays,\n  sowDocUrl,\n  sowDocId,\n  rationaleDocUrl,\n  rationaleDocId,\n  transcriptFileId,\n  today,\n  clientFolderSafeName\n} }];"
      }
    },
    {
      "id": "w3_n3_mark_approved",
      "name": "Mark SOW Approved in Tracker",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [
        910,
        300
      ],
      "parameters": {
        "operation": "update",
        "documentId": {
          "__rl": true,
          "value": "={{$vars.AIIR_PRICING_SHEET_ID}}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "Tracker",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "sow_approval_status": "APPROVED",
            "sow_approved_by": "Reviewer (email link)",
            "sow_approved_at": "={{ new Date().toISOString() }}"
          }
        },
        "where": {
          "values": [
            {
              "column": "engagement_id",
              "condition": "equals",
              "conditionValue": "={{ $json.engagementId }}"
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_GOOGLE_SHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
