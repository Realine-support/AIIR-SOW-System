      "parameters": {
        "sendTo": "={{ $('Collect Subfolder IDs').first().json.clientEmail }}",
        "subject": "Statement of Work — AIIR Executive Coaching Engagement",
        "emailType": "html",
        "message": "=<html><body style='font-family:Arial,sans-serif;line-height:1.6;color:#333;'>\n<p>Dear {{ $('Collect Subfolder IDs').first().json.coacheeName }},</p>\n\n<p>Thank you for your interest in AIIR Consulting's executive coaching program. Please find your Statement of Work attached via the link below.</p>\n\n<p>This document outlines the scope, timeline, and investment for your engagement. Please review it carefully and reach out with any questions.</p>\n\n<p style='margin:20px 0;'>\n  <a href='{{ $('Collect Subfolder IDs').first().json.sowDocUrl }}' style='background:#1a73e8;color:white;padding:12px 24px;text-decoration:none;border-radius:4px;font-size:15px;'>📄 View Statement of Work</a>\n</p>\n\n<p>We look forward to partnering with you on this journey.</p>\n\n<p>Warm regards,<br>\nMegan Marshall<br>\nAIIR Consulting</p>\n\n<hr style='border:none;border-top:1px solid #eee;margin:30px 0;'>\n<p style='color:#999;font-size:11px;'>AIIR Consulting | Executive Coaching & Leadership Development</p>\n</body></html>",
        "options": {}
      },
      "credentials": {
        "gmailOAuth2": {
          "id": "REPLACE_WITH_GMAIL_CREDENTIAL_ID",
          "name": "Gmail account"
