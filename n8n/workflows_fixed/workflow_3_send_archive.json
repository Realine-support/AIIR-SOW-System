      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1790,
        300
      ],
      "parameters": {
        "jsCode": "const prevData = $('Build Archive Folder Paths').first().json;\nconst sowFolder = $('Create SOWs Subfolder').first().json;\nconst transcriptsFolder = $('Create Transcripts Subfolder').first().json;\nconst pricingFolder = $('Create Pricing Subfolder').first().json;\n\nconst sowsFolderId = sowFolder.id;\nconst transcriptsFolderId = transcriptsFolder.id;\nconst pricingFolderId = pricingFolder.id;\nconst archiveFolderUrl = `https://drive.google.com/drive/folders/${prevData.clientFolderId}`;\n\nreturn [{ json: { ...prevData, sowsFolderId, transcriptsFolderId, pricingFolderId, archiveFolderUrl } }];"
      }
    },
